APP_NAME=DocAudit
APP_VERSION=0.1.0
DOC_AUDIT_PROCESSING_MODE=sync
DOC_AUDIT_AUTO_CREATE_SCHEMA=false
# Leave UPLOAD_DIR unset on Vercel so the app uses the platform temp directory.
# The Vercel Supabase integration injects POSTGRES_URL, POSTGRES_URL_NON_POOLING,
# POSTGRES_PRISMA_URL and the SUPABASE_* variables automatically.
# If you need to set the connection manually, prefer POSTGRES_URL_NON_POOLING.
POSTGRES_URL=postgresql://postgres:change-me@db.project-ref.supabase.co:5432/postgres
POSTGRES_URL_NON_POOLING=postgresql://postgres:change-me@db.project-ref.supabase.co:5432/postgres
SUPABASE_URL=https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/ministral-3b-2512
OPENROUTER_CONNECT_TIMEOUT_SECONDS=5
OPENROUTER_WRITE_TIMEOUT_SECONDS=10
OPENROUTER_READ_TIMEOUT_SECONDS=30
OPENROUTER_POOL_TIMEOUT_SECONDS=5
OPENROUTER_TIMEOUT_RETRIES=2
OPENROUTER_RATE_LIMIT_ENABLED=true
OPENROUTER_RATE_LIMIT_COOLDOWN_SECONDS=2
OPENROUTER_RATE_LIMIT_RETRIES=6
OPENROUTER_RATE_LIMIT_RETRY_SPREAD_SECONDS=1
OPENROUTER_REFERER=https://docaudit.seu-dominio.com
OPENROUTER_TITLE=DocAudit
UPLOAD_MAX_FILES=5
UPLOAD_MAX_SIZE_BYTES=5242880
REDIS_URL=rediss://default:change-me@your-redis-host:6379
CELERY_DEFAULT_QUEUE=celery
CELERY_OBSERVED_QUEUES=celery
CELERY_INSPECT_TIMEOUT_SECONDS=1.5
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=55
CELERY_TASK_TIME_LIMIT_SECONDS=60
CELERY_WORKER_CONCURRENCY=2
OBSERVABILITY_EVENT_RETENTION=2000
CORS_ALLOW_ORIGINS=https://docaudit.seu-dominio.com
CORS_ALLOW_ORIGIN_REGEX=
