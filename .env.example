APP_NAME=DocAudit
APP_VERSION=0.1.0
POSTGRES_DB=docaudit
POSTGRES_USER=docaudit
POSTGRES_PASSWORD=docaudit
# Use localhost when running Postgres outside Docker.
# For a lightweight local run without Postgres, you can use:
# DATABASE_URL=sqlite+pysqlite:///./docaudit.db
DATABASE_URL=postgresql+psycopg://docaudit:docaudit@db:5432/docaudit
REDIS_URL=redis://redis:6379/0
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.5:free
OPENROUTER_REFERER=
OPENROUTER_TITLE=DocAudit
