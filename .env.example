APP_NAME=DocAudit
APP_VERSION=0.1.0
DOC_AUDIT_PROCESSING_MODE=sync
UPLOAD_DIR=storage/uploads
UPLOAD_MAX_FILES=250
POSTGRES_DB=docaudit
POSTGRES_USER=docaudit
POSTGRES_PASSWORD=docaudit
DATABASE_URL=postgresql+psycopg://docaudit:docaudit@127.0.0.1:5432/docaudit
REDIS_URL=redis://redis:6379/0
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/ministral-3b-2512
OPENROUTER_CONNECT_TIMEOUT_SECONDS=5
OPENROUTER_WRITE_TIMEOUT_SECONDS=10
OPENROUTER_READ_TIMEOUT_SECONDS=30
OPENROUTER_POOL_TIMEOUT_SECONDS=5
OPENROUTER_TIMEOUT_RETRIES=2
OPENROUTER_RATE_LIMIT_ENABLED=true
OPENROUTER_RATE_LIMIT_COOLDOWN_SECONDS=2
OPENROUTER_RATE_LIMIT_RETRIES=6
OPENROUTER_RATE_LIMIT_RETRY_SPREAD_SECONDS=1
CELERY_DEFAULT_QUEUE=celery
CELERY_OBSERVED_QUEUES=celery
CELERY_INSPECT_TIMEOUT_SECONDS=1.5
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=55
CELERY_TASK_TIME_LIMIT_SECONDS=60
CELERY_WORKER_CONCURRENCY=2
OBSERVABILITY_EVENT_RETENTION=2000
OPENROUTER_REFERER=
OPENROUTER_TITLE=DocAudit
